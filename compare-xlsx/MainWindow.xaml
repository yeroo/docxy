<Window x:Class="XlsxyCompare.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="xlsxy ⇄ Excel"
        WindowStyle="None" ResizeMode="NoResize"
        Topmost="True" ShowInTaskbar="True"
        Background="#12211A" Foreground="#E6E6E6"
        UseLayoutRounding="True" FontFamily="Segoe UI" FontSize="12">

  <Window.Resources>
    <!-- TreeViewItem's default template doesn't inherit Foreground, so set it
         here for every node (otherwise folder/leaf text renders black). -->
    <Style TargetType="TreeViewItem">
      <Setter Property="Foreground" Value="#E6E6E6"/>
      <Setter Property="Padding" Value="2,1"/>
    </Style>
  </Window.Resources>

  <Grid>
    <!-- Full browser, shown while expanded -->
    <DockPanel x:Name="ContentPanel" Margin="0">
      <Border DockPanel.Dock="Top" Background="#0C1712" Padding="10,8">
        <Grid>
          <StackPanel>
            <TextBlock Text="xlsxy ⇄ Excel" FontSize="15" FontWeight="SemiBold" Foreground="#79E0A8"/>
            <TextBlock x:Name="SubTitle" Text="pick a workbook — opens in xlsxy + Excel side by side"
                       Foreground="#8AA695" FontSize="11" Margin="0,2,0,0"/>
          </StackPanel>
          <Button x:Name="CloseBtn" Content="✕" Width="26" Height="24"
                  HorizontalAlignment="Right" VerticalAlignment="Top"
                  Background="Transparent" Foreground="#C0D4C6" BorderThickness="0"
                  Click="CloseBtn_Click"/>
        </Grid>
      </Border>

      <Border DockPanel.Dock="Top" Padding="10,8,10,4">
        <StackPanel>
          <TextBox x:Name="SearchBox" Padding="6,4" Background="#1E2E26" Foreground="#E6E6E6"
                   BorderBrush="#2F4A3C" CaretBrush="#E6E6E6" TextChanged="Search_Changed"/>
          <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
            <TextBlock Text="Group by:" VerticalAlignment="Center" Foreground="#8AA695" Margin="0,0,8,0"/>
            <RadioButton x:Name="GroupCategory" Content="Category" IsChecked="True"
                         Foreground="#E6E6E6" Margin="0,0,10,0" Checked="Grouping_Changed"/>
            <RadioButton x:Name="GroupTag" Content="Tag" Foreground="#E6E6E6" Margin="0,0,10,0"
                         Checked="Grouping_Changed"/>
            <RadioButton x:Name="GroupFolder" Content="Folder" Foreground="#E6E6E6"
                         Checked="Grouping_Changed"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <Border DockPanel.Dock="Bottom" Background="#0C1712" Padding="10,6">
        <TextBlock x:Name="StatusText" Text="" Foreground="#8AA695" TextTrimming="CharacterEllipsis"/>
      </Border>

      <TreeView x:Name="Tree" Background="Transparent" BorderThickness="0" Foreground="#E6E6E6"
                Margin="4,4,4,4"
                SelectedItemChanged="Tree_SelectedItemChanged"
                KeyDown="Tree_KeyDown">
        <TreeView.ContextMenu>
          <ContextMenu>
            <MenuItem Header="Copy file path  (Ctrl+C)" Click="CopyPath_Click"/>
          </ContextMenu>
        </TreeView.ContextMenu>
      </TreeView>
    </DockPanel>

    <!-- Thin strip, shown while collapsed; hovering the window expands it -->
    <Border x:Name="StripPanel" Background="#0C1712" Visibility="Collapsed">
      <TextBlock Text="▦  C O R P U S   ·   hover" Foreground="#79E0A8"
                 HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="12">
        <TextBlock.LayoutTransform>
          <RotateTransform Angle="90"/>
        </TextBlock.LayoutTransform>
      </TextBlock>
    </Border>
  </Grid>
</Window>
