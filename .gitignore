/target
**/*.rs.bk
# Coverage output (generated by `cargo llvm-cov`; uploaded to Codecov in CI).
/lcov.info
# Third-party test corpus — lives in the separate github.com/yeroo/docxy-corpus
# repo (see corpus/README.md). Populate these locally from there; the crates
# don't need them (only the first-party corpus/xlsx/ oracle, which is tracked).
/corpus/files/
/corpus/xlsx-ext/
/corpus/classification.json
/corpus/classification-xlsx.json
/sample-output.pdf
/cli-output.pdf
/sample-resaved.docx
# Assembled COM-shim deployment package (built by tools/package-shims.ps1 from
# release binaries + the committed .tlb/scripts; regenerate, don't commit).
/dist/
# mmcompare: real-mermaid.js-vs-ours visual comparison harness (dev tool,
# scripts/mmcompare) — rendered PNGs/HTMLs and its own node_modules.
/scripts/mmcompare/out/
/scripts/mmcompare/node_modules/

# GPUI UI suite build output (separate workspace)
/suite/target/
